# PayChangu Payment Gateway Configuration
# Get your credentials from https://paychangu.com dashboard

# API Keys (use sandbox keys for testing)
PAYCHANGU_PUBLIC_KEY=pk_sandbox_your_public_key_here
PAYCHANGU_SECRET_KEY=sk_sandbox_your_secret_key_here
PAYCHANGU_WEBHOOK_SECRET=whsec_your_webhook_secret_here

# Environment: 'sandbox' for testing, 'production' for live
PAYCHANGU_ENVIRONMENT=sandbox

# Webhook URL (update with your ngrok URL for local testing)
# Format: https://YOUR_NGROK_URL/nyumbaops/us-central1/api/v1/public/webhooks/paychangu
PAYCHANGU_WEBHOOK_URL=https://your-ngrok-url.ngrok.io/nyumbaops/us-central1/api/v1/public/webhooks/paychangu

# Application URLs
PUBLIC_URL=http://localhost:3001
DASHBOARD_URL=http://localhost:3000

# Firebase Configuration (for emulator)
FIREBASE_STORAGE_BUCKET=nyumbaops.firebasestorage.app
FIRESTORE_EMULATOR_HOST=127.0.0.1:8080
FIREBASE_AUTH_EMULATOR_HOST=127.0.0.1:9099
FIREBASE_STORAGE_EMULATOR_HOST=127.0.0.1:9199

# Rate Limiting
INQUIRY_RATE_LIMIT=5
