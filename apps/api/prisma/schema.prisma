generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Currency {
  MWK
  USD
}

enum PropertyStatus {
  ACTIVE
  INACTIVE
  MAINTENANCE
}

enum TransactionType {
  REVENUE
  EXPENSE
}

enum CategoryType {
  REVENUE
  EXPENSE
}

enum GuestSource {
  AIRBNB
  LOCAL
  REFERRAL
  REPEAT
}

enum BookingStatus {
  PENDING
  CONFIRMED
  CHECKED_IN
  COMPLETED
  CANCELLED
}

enum LoanStatus {
  ACTIVE
  SETTLED
}

enum WorkStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum WorkPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum WorkCategory {
  PLUMBING
  ELECTRICAL
  PAINTING
  CLEANING
  CARPENTRY
  APPLIANCE
  HVAC
  LANDSCAPING
  GENERAL
  OTHER
}

enum InventoryCategory {
  CLEANING_SUPPLIES
  TOOLS
  BEDDING
  KITCHEN
  TOILETRIES
  FURNITURE
  APPLIANCES
  SAFETY
  GENERAL
  OTHER
}

enum StockMovementType {
  IN
  OUT
}

model User {
  id           String    @id @default(uuid())
  email        String    @unique
  name         String?
  passwordHash String?   @map("password_hash")
  telegramId   String?   @unique @map("telegram_id")
  telegramUsername String? @map("telegram_username")
  role         String    @default("OWNER")
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  categories   Category[]
  transactions Transaction[]
  guests       Guest[]
  bookings     Booking[]
  checkedInBookings  Booking[] @relation("BookingCheckedInBy")
  checkedOutBookings Booking[] @relation("BookingCheckedOutBy")
  auditLogs    AuditLog[]
  notificationSettings NotificationSettings?
  loans          Loan[]
  loanRepayments LoanRepayment[]
  works          Work[]
  stockMovements StockMovement[]
  inventoryItems InventoryItem[]
}

model Property {
  id                 String         @id @default(uuid())
  name               String
  propertyType       String?        @map("property_type")
  location           String?
  address            String?
  description        String?
  spaceDescription   String?        @map("space_description")
  guestAccess        String?        @map("guest_access")
  otherDetails       String?        @map("other_details")
  highlights         String[]       @default([])
  bedrooms           Int
  beds               Int?
  bathrooms          Int
  maxGuests          Int
  propertySize       Float?         @map("property_size")
  bedTypes           String[]       @default([])
  nightlyRate        Int?
  currency           Currency
  weekendRate        Int?           @map("weekend_rate")
  weeklyDiscount     Int?           @map("weekly_discount")
  monthlyDiscount    Int?           @map("monthly_discount")
  cleaningFee        Int?           @map("cleaning_fee")
  securityDeposit    Int?           @map("security_deposit")
  extraGuestFee      Int?           @map("extra_guest_fee")
  minimumStay        Int?           @map("minimum_stay")
  maximumStay        Int?           @map("maximum_stay")
  checkInTime        String?        @map("check_in_time")
  checkOutTime       String?        @map("check_out_time")
  smokingAllowed     Boolean        @default(false) @map("smoking_allowed")
  petsAllowed        Boolean        @default(false) @map("pets_allowed")
  eventsAllowed      Boolean        @default(false) @map("events_allowed")
  quietHours         String?        @map("quiet_hours")
  additionalRules    String?        @map("additional_rules")
  cancellationPolicy String?        @map("cancellation_policy")
  latitude           Float?
  longitude          Float?
  googleMapsUrl      String?        @map("google_maps_url")
  slug               String?        @unique
  seoTitle           String?        @map("seo_title")
  seoDescription     String?        @map("seo_description")
  seoKeywords        String[]       @default([]) @map("seo_keywords")
  status             PropertyStatus @default(ACTIVE)
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt

  transactions        Transaction[]
  transactionMappings TransactionProperty[]
  bookings            Booking[]
  amenities           PropertyAmenity[]
  images              PropertyImage[]
  calendarSync        CalendarSync?
  works               Work[]
  inventoryItems      InventoryItem[]
}

model Amenity {
  id          String   @id @default(uuid())
  name        String
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  properties PropertyAmenity[]

  @@unique([name])
}

model PropertyAmenity {
  id         String   @id @default(uuid())
  propertyId String
  amenityId  String
  createdAt  DateTime @default(now())

  property Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  amenity  Amenity  @relation(fields: [amenityId], references: [id], onDelete: Cascade)

  @@unique([propertyId, amenityId])
  @@index([propertyId])
  @@index([amenityId])
}

model PropertyImage {
  id         String   @id @default(uuid())
  propertyId String
  url        String
  alt        String?
  sortOrder  Int      @default(0)
  isCover    Boolean  @default(false)
  createdAt  DateTime @default(now())

  property Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@index([propertyId, sortOrder])
  @@index([propertyId, isCover])
}

model Category {
  id        String       @id @default(uuid())
  name      String
  type      CategoryType
  isSystem  Boolean      @default(false)
  createdBy String
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  creator      User          @relation(fields: [createdBy], references: [id])
  transactions Transaction[]

  @@unique([name, type])
}

model Transaction {
  id         String          @id @default(uuid())
  propertyId String?
  bookingId  String?         @map("booking_id")
  type       TransactionType
  categoryId String
  amount     Int
  currency   Currency
  date       DateTime
  notes      String?
  createdVia String          @default("DASHBOARD") @map("created_via")
  telegramMessageId BigInt?  @map("telegram_message_id")
  createdBy  String
  createdAt  DateTime        @default(now())
  updatedAt  DateTime        @updatedAt

  property            Property?            @relation(fields: [propertyId], references: [id])
  booking             Booking?             @relation(fields: [bookingId], references: [id])
  category            Category             @relation(fields: [categoryId], references: [id])
  creator             User                 @relation(fields: [createdBy], references: [id])
  transactionMappings TransactionProperty[]
  work                Work?
  stockMovement       StockMovement?

  @@index([propertyId])
  @@index([bookingId])
  @@index([categoryId])
  @@index([date])
}

model TransactionProperty {
  id            String   @id @default(uuid())
  transactionId String
  propertyId    String
  amount        Int?
  share         Float?
  createdAt     DateTime @default(now())

  transaction Transaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  property    Property    @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@unique([transactionId, propertyId])
}

model AuditLog {
  id           String   @id @default(uuid())
  action       String
  resourceType String
  resourceId   String
  userId       String
  details      Json?
  createdAt    DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@index([resourceType, resourceId])
  @@index([userId])
}

model NotificationSettings {
  id String @id @default(uuid())
  userId String @unique @map("user_id")
  newInquiryTelegram Boolean @default(true) @map("new_inquiry_telegram")
  newInquiryEmail Boolean @default(false) @map("new_inquiry_email")
  bookingConfirmedTelegram Boolean @default(true) @map("booking_confirmed_telegram")
  bookingConfirmedEmail Boolean @default(false) @map("booking_confirmed_email")
  dailySummaryTelegram Boolean @default(false) @map("daily_summary_telegram")
  dailySummaryEmail Boolean @default(false) @map("daily_summary_email")
  dailySummaryTime String? @default("18:00") @map("daily_summary_time")
  weeklySummaryTelegram Boolean @default(false) @map("weekly_summary_telegram")
  weeklySummaryDay Int @default(1) @map("weekly_summary_day")
  weeklySummaryHour Int @default(8) @map("weekly_summary_hour")
  workRemindersTelegram Boolean @default(true) @map("work_reminders_telegram")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("notification_settings")
}

model Guest {
  id        String      @id @default(uuid())
  name      String
  email     String?
  phone     String?
  source    GuestSource
  notes     String?
  rating    Int?
  createdBy String
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  creator  User      @relation(fields: [createdBy], references: [id])
  bookings Booking[]

  @@index([source])
}

model Booking {
  id            String        @id @default(uuid())
  guestId       String
  propertyId    String
  status        BookingStatus @default(PENDING)
  checkInDate   DateTime
  checkOutDate  DateTime
  actualCheckIn DateTime?
  actualCheckOut DateTime?
  checkInNotes  String?
  checkOutNotes String?
  checkOutIssueType String? @map("check_out_issue_type")
  checkedInBy  String? @map("checked_in_by")
  checkedOutBy String? @map("checked_out_by")
  notes         String?
  source        String        @default("MANUAL")
  externalId    String?       @map("external_id")
  isSyncedBooking Boolean     @default(false) @map("is_synced_booking")
  createdBy     String
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  guest    Guest    @relation(fields: [guestId], references: [id], onDelete: Cascade)
  property Property @relation(fields: [propertyId], references: [id])
  creator  User     @relation(fields: [createdBy], references: [id])
  checkedInByUser User? @relation("BookingCheckedInBy", fields: [checkedInBy], references: [id])
  checkedOutByUser User? @relation("BookingCheckedOutBy", fields: [checkedOutBy], references: [id])
  transactions Transaction[]

  @@index([guestId])
  @@index([propertyId])
  @@index([checkInDate])
  @@index([checkOutDate])
  @@index([status])
  @@index([source])
  @@index([externalId])
}

model CalendarSync {
  id              String    @id @default(uuid())
  propertyId      String    @unique @map("property_id")
  platform        String
  icalUrl         String    @map("ical_url")
  isEnabled       Boolean   @default(true) @map("is_enabled")
  lastSyncAt      DateTime? @map("last_sync_at")
  lastSyncStatus  String?   @map("last_sync_status")
  lastSyncError   String?   @map("last_sync_error")
  syncFrequency   Int       @default(30) @map("sync_frequency")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  property        Property  @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  syncLogs        CalendarSyncLog[]

  @@index([propertyId])
  @@index([isEnabled])
  @@map("calendar_syncs")
}

model CalendarSyncLog {
  id              String        @id @default(uuid())
  calendarSyncId  String        @map("calendar_sync_id")
  status          String
  eventsImported  Int           @default(0) @map("events_imported")
  eventsSkipped   Int           @default(0) @map("events_skipped")
  errorMessage    String?       @map("error_message")
  syncDuration    Int?          @map("sync_duration")
  createdAt       DateTime      @default(now()) @map("created_at")

  calendarSync    CalendarSync  @relation(fields: [calendarSyncId], references: [id], onDelete: Cascade)

  @@index([calendarSyncId])
  @@index([createdAt])
  @@map("calendar_sync_logs")
}

model Loan {
  id            String     @id @default(uuid())
  lenderName    String     @map("lender_name")
  amount        Int
  amountRepaid  Int        @default(0) @map("amount_repaid")
  status        LoanStatus @default(ACTIVE)
  dateTaken     DateTime   @map("date_taken")
  dueDate       DateTime?  @map("due_date")
  notes         String?
  createdBy     String     @map("created_by")
  createdAt     DateTime   @default(now()) @map("created_at")
  updatedAt     DateTime   @updatedAt @map("updated_at")

  creator       User       @relation(fields: [createdBy], references: [id])
  repayments    LoanRepayment[]

  @@index([status])
  @@index([createdBy])
  @@map("loans")
}

model LoanRepayment {
  id        String   @id @default(uuid())
  loanId    String   @map("loan_id")
  amount    Int
  date      DateTime
  notes     String?
  createdBy String   @map("created_by")
  createdAt DateTime @default(now()) @map("created_at")

  loan      Loan     @relation(fields: [loanId], references: [id], onDelete: Cascade)
  creator   User     @relation(fields: [createdBy], references: [id])

  @@index([loanId])
  @@map("loan_repayments")
}

model Work {
  id            String       @id @default(uuid())
  propertyId    String       @map("property_id")
  title         String
  description   String?
  status        WorkStatus   @default(PENDING)
  priority      WorkPriority @default(MEDIUM)
  category      WorkCategory @default(GENERAL)
  scheduledDate DateTime?    @map("scheduled_date")
  completedDate DateTime?    @map("completed_date")
  estimatedCost Int?         @map("estimated_cost")
  actualCost    Int?         @map("actual_cost")
  currency      Currency     @default(MWK)
  transactionId String?      @unique @map("transaction_id")
  notes         String?
  createdBy     String       @map("created_by")
  createdAt     DateTime     @default(now()) @map("created_at")
  updatedAt     DateTime     @updatedAt @map("updated_at")

  property       Property      @relation(fields: [propertyId], references: [id])
  transaction    Transaction?  @relation(fields: [transactionId], references: [id])
  creator        User          @relation(fields: [createdBy], references: [id])
  stockMovements StockMovement[]

  @@index([propertyId])
  @@index([status])
  @@index([scheduledDate])
  @@map("works")
}

model InventoryItem {
  id          String            @id @default(uuid())
  propertyId  String            @map("property_id")
  name        String
  category    InventoryCategory @default(GENERAL)
  unit        String            @default("unit")
  quantity    Int               @default(0)
  minQuantity Int               @default(0) @map("min_quantity")
  unitCost    Int?              @map("unit_cost")
  currency    Currency          @default(MWK)
  notes       String?
  createdBy   String            @map("created_by")
  createdAt   DateTime          @default(now()) @map("created_at")
  updatedAt   DateTime          @updatedAt @map("updated_at")

  property  Property      @relation(fields: [propertyId], references: [id])
  creator   User          @relation(fields: [createdBy], references: [id])
  movements StockMovement[]

  @@unique([propertyId, name])
  @@index([propertyId])
  @@map("inventory_items")
}

model StockMovement {
  id              String            @id @default(uuid())
  inventoryItemId String            @map("inventory_item_id")
  workId          String?           @map("work_id")
  type            StockMovementType
  quantity        Int
  unitCost        Int?              @map("unit_cost")
  currency        Currency          @default(MWK)
  transactionId   String?           @unique @map("transaction_id")
  notes           String?
  createdBy       String            @map("created_by")
  createdAt       DateTime          @default(now()) @map("created_at")

  inventoryItem InventoryItem @relation(fields: [inventoryItemId], references: [id], onDelete: Cascade)
  work          Work?         @relation(fields: [workId], references: [id])
  transaction   Transaction?  @relation(fields: [transactionId], references: [id])
  creator       User          @relation(fields: [createdBy], references: [id])

  @@index([inventoryItemId])
  @@index([workId])
  @@index([createdAt])
  @@map("stock_movements")
}

