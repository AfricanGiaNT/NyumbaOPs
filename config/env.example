DATABASE_URL=postgresql://USER:PASSWORD@HOST:PORT/DATABASE
JWT_SECRET=replace_me

# Cloudflare R2 (S3 compatible) for property images
R2_ENDPOINT=https://<account_id>.r2.cloudflarestorage.com
R2_REGION=auto
R2_ACCESS_KEY_ID=replace_me
R2_SECRET_ACCESS_KEY=replace_me
R2_BUCKET=nyumbaops-public
R2_PUBLIC_BASE_URL=https://cdn.example.com
R2_UPLOAD_URL_TTL_SECONDS=900

# PayChangu Configuration
PAYCHANGU_PUBLIC_KEY=replace_me
PAYCHANGU_SECRET_KEY=replace_me
PAYCHANGU_WEBHOOK_SECRET=replace_me
PAYCHANGU_ENVIRONMENT=sandbox
PAYCHANGU_WEBHOOK_URL=https://functions.example.com/api/v1/public/webhooks/paychangu

# Application URLs
PUBLIC_URL=https://your-public-site.example.com
DASHBOARD_URL=https://dashboard.example.com

# SendGrid Email
SENDGRID_API_KEY=replace_me
SENDGRID_FROM_EMAIL=bookings@nyumbastays.com
SENDGRID_FROM_NAME=Nyumba Stays

# Rate Limiting
INQUIRY_RATE_LIMIT=5

# Telegram Bot
TELEGRAM_BOT_TOKEN=replace_me
TELEGRAM_WEBHOOK_SECRET=replace_me

# Google Maps (used in dashboard + public site for interactive maps)
# Get your key at: https://console.cloud.google.com/apis/credentials
# Enable: Maps JavaScript API + Geocoding API
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=replace_me
